# ── Supabase ───────────────────────────────────────────────────────────────────
# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site ───────────────────────────────────────────────────────────────────────
# Full URL of your deployment — used in password-reset redirect links
NEXT_PUBLIC_SITE_URL=https://shiftai.space

# ── Admin Seed ─────────────────────────────────────────────────────────────────
# Protect POST /api/admin/seed — rotate immediately if compromised
ADMIN_BYPASS_TOKEN=replace-with-a-long-random-string

# Initial passwords for seeded admin accounts — rotate after first login
SEED_PASSWORD_NICO=replace-with-strong-password
SEED_PASSWORD_JOE=replace-with-strong-password
